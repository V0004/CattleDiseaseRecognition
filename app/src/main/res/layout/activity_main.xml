<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/green_light"
    tools:context=".MainActivity">

    <!-- Header Section -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAudio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_speaker"
        app:backgroundTint="@color/green_primary"
        app:tint="@android:color/white"
        app:fabSize="mini"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:contentDescription="Recite page content" />

    <TextView
        android:id="@+id/tvDetectionResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:text="@string/main_title"
        android:textColor="@color/green_primary"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Image Display Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:strokeColor="@color/green_primary"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@+id/guidelineActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDetectionResult">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F0F0F0"
            android:contentDescription="@string/image"
            android:onClick="showImagePicker"
            android:scaleType="centerInside"
            android:src="@drawable/cowlogo2"
            android:alpha="0.6"/>

    </com.google.android.material.card.MaterialCardView>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.65" />

    <!-- Action Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guidelineActions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpload"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:onClick="showImagePicker"
                android:text="@string/upload_image"
                app:cornerRadius="16dp"
                app:strokeColor="@color/green_primary"
                android:textColor="@color/green_primary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerify"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:onClick="predict"
                android:text="@string/verify_image"
                app:cornerRadius="16dp"
                app:strokeColor="@color/green_primary"
                android:textColor="@color/green_primary"/>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manualCropButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/manual_crop"
            app:cornerRadius="16dp"
            app:strokeColor="@color/green_primary"
            android:textColor="@color/green_primary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/classifyButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="16dp"
            android:text="@string/autocrop_predict"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/green_primary"
            app:cornerRadius="20dp"
            app:elevation="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
